# Alchemy Robinhood Chain (4663) app key. Get one at dashboard.alchemy.com (create app -> Robinhood Chain).
ALCHEMY_KEY=your_alchemy_key_here

# Optional overrides (sane defaults baked in)
# ALCHEMY_RH_RPC=https://robinhood-mainnet.g.alchemy.com/v2
# RH_BLOCKSCOUT=https://robinhoodchain.blockscout.com

# Optional: global rate limiting for the public API routes (Upstash Redis / Vercel KV).
# Without these, the limiter falls back to per-instance in-memory (weak against a
# concurrent burst). Set both to enable a real cross-instance limit. You can reuse
# an existing Upstash/KV instance — keys are namespaced `rhsm:rl:`.
# KV_REST_API_URL=https://your-db.upstash.io
# KV_REST_API_TOKEN=your_kv_rest_token
